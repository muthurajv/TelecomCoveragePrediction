# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# GCP
GCP_PROJECT_ID=telco-pci-prod
GCP_REGION=us-central1

# BigQuery datasets
BQ_DATASET_RAW=pci_raw
BQ_DATASET_CURATED=pci_curated
BQ_DATASET_FEATURES=pci_features
BQ_DATASET_SCORING=pci_scoring
BQ_DATASET_REPORTING=pci_reporting

# GCS
GCS_DATA_LAKE_BUCKET=telco-pci-prod-data-lake
GCS_ML_ARTIFACTS_BUCKET=telco-pci-prod-ml-artifacts
GCS_DATAFLOW_TEMP=gs://telco-pci-prod-dataflow-temp/tmp

# Pub/Sub
PUBSUB_RF_TELEMETRY_TOPIC=rf-telemetry-ingest
PUBSUB_RF_SUBSCRIPTION=rf-telemetry-dataflow-sub

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=pci-coverage-gap-classifier

# Vertex AI
VERTEX_PIPELINE_ROOT=gs://telco-pci-prod-ml-artifacts/pipeline_runs
VERTEX_TRAINING_SA=pci-vertex-sa@telco-pci-prod.iam.gserviceaccount.com

# API
API_PORT=8000
